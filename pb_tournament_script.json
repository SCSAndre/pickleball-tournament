function applyStandingsFormatting(std) {
    // Point differential colors
  const diffPositive = SpreadsheetApp.newConditionalFormatRule()
    .whenNumberGreaterThan(0)
    .setBackground(CONFIG.COLORS.WIN)
    .setBold(true)
    .setRanges([std.getRange('G2:G9')
    ])
    .build();
  
  const diffNegative = SpreadsheetApp.newConditionalFormatRule()
    .whenNumberLessThan(0)
    .setBackground(CONFIG.COLORS.LOSS)
    .setRanges([std.getRange('G2:G9')
    ])
    .build();
  
  // Win % gradient
  const winPctGradient = SpreadsheetApp.newConditionalFormatRule()
    .setGradientMaxpointWithValue(CONFIG.COLORS.SUCCESS, SpreadsheetApp.InterpolationType.NUMBER, '1')
    .setGradientMidpointWithValue('#ffffff', SpreadsheetApp.InterpolationType.NUMBER, '0.5')
    .setGradientMinpointWithValue(CONFIG.COLORS.DANGER, SpreadsheetApp.InterpolationType.NUMBER, '0')
    .setRanges([std.getRange('I2:I9')
    ])
    .build();
  
  // Rank highlighting
  const rank1 = SpreadsheetApp.newConditionalFormatRule()
    .whenNumberEqualTo(1)
    .setBackground(CONFIG.COLORS.GOLD)
    .setBold(true)
    .setRanges([std.getRange('H2:H9')
    ])
    .build();
  
  const rank2 = SpreadsheetApp.newConditionalFormatRule()
    .whenNumberEqualTo(2)
    .setBackground(CONFIG.COLORS.SILVER)
    .setBold(true)
    .setRanges([std.getRange('H2:H9')
    ])
    .build();
  
  const rank3 = SpreadsheetApp.newConditionalFormatRule()
    .whenNumberEqualTo(3)
    .setBackground(CONFIG.COLORS.BRONZE)
    .setBold(true)
    .setRanges([std.getRange('H2:H9')
    ])
    .build();
  
  const rules = [diffPositive, diffNegative, winPctGradient, rank1, rank2, rank3
    ];
  std.setConditionalFormatRules(rules);
}

function applyStandingsAdvancedFormatting() {
  const ss = SpreadsheetApp.getActive();
  const std = ss.getSheetByName('Standings');
  if (!std) return;
  
