function createPlayerProfiles(ss) {
  if (!ss) ss = SpreadsheetApp.getActive();
  
  const profiles = getOrCreateSheet(ss, 'Player Profiles');
  profiles.clear();
  
  // Title
  profiles.getRange('A1').setValue('🎮 INDIVIDUAL PLAYER PROFILES').setFontSize(18).setFontWeight('bold');
  
  const players = ['Dedezito','Guguzito','Cebolito','Nayzito','Michelito','Tiaguito','Marcito','Fernandito'
    ];
  
  let currentRow = 3;
  
  players.forEach((player, idx) => {
    const startRow = currentRow;
    
    // Player Header
    profiles.getRange(currentRow,
        1,
        1,
        6).merge().setValue(`${idx + 1
        }. ${player
        }`)
      .setFontSize(14).setFontWeight('bold').setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff');
    currentRow++;
    
    // Basic Stats
    profiles.getRange(currentRow,
        1,
        1,
        6).merge().setValue('📊 BASIC STATISTICS')
      .setFontWeight('bold').setBackground('#e8f0fe');
    currentRow++;
    
    profiles.getRange(currentRow,
        1).setValue('Current Rank:');
    profiles.getRange(currentRow,
        2).setFormula(`=VLOOKUP("${player}",Standings!A2:H9,
        8,FALSE)`);
    profiles.getRange(currentRow,
        3).setValue('Total Points:');
    profiles.getRange(currentRow,
        4).setFormula(`=VLOOKUP("${player}",Standings!A2:B9,
        2,FALSE)`);
    currentRow++;
    
    profiles.getRange(currentRow,
        1).setValue('Record (W-L):');
    profiles.getRange(currentRow,
        2).setFormula(
      `=VLOOKUP("${player}",Standings!A2:C9,
        3,FALSE)&"-"&VLOOKUP("${player}",Standings!A2:D9,
        4,FALSE)`
    );
    profiles.getRange(currentRow,
        3).setValue('Win %:');
    profiles.getRange(currentRow,
        4).setFormula(`=VLOOKUP("${player}",Standings!A2:I9,
        9,FALSE)`);
    profiles.getRange(currentRow,
        4).setNumberFormat('0.0%');
    currentRow++;
    
    profiles.getRange(currentRow,
        1).setValue('Points For:');
    profiles.getRange(currentRow,
        2).setFormula(`=VLOOKUP("${player}",Standings!A2:E9,
        5,FALSE)`);
    profiles.getRange(currentRow,
        3).setValue('Points Against:');
    profiles.getRange(currentRow,
        4).setFormula(`=VLOOKUP("${player}",Standings!A2:F9,
        6,FALSE)`);
    currentRow++;
    
    profiles.getRange(currentRow,
        1).setValue('Point Diff:');
    profiles.getRange(currentRow,
        2).setFormula(`=VLOOKUP("${player}",Standings!A2:G9,
        7,FALSE)`);
    profiles.getRange(currentRow,
        3).setValue('Avg Score:');
    profiles.getRange(currentRow,
        4).setFormula(
      `=VLOOKUP("${player}",Standings!A2:E9,
        5,FALSE)/(VLOOKUP("${player}",Standings!A2:C9,
        3,FALSE)+VLOOKUP("${player}",Standings!A2:D9,
        4,FALSE))`
    );
    profiles.getRange(currentRow,
        4).setNumberFormat('0.0');
    currentRow++;
    
    // Performance Metrics
    currentRow++;
    profiles.getRange(currentRow,
        1,
        1,
        6).merge().setValue('📈 PERFORMANCE METRICS')
      .setFontWeight('bold').setBackground('#fff2cc');
    currentRow++;
    
    profiles.getRange(currentRow,
        1).setValue('Form:');
    profiles.getRange(currentRow,
        2).setValue('--'); // Will be calculated
    profiles.getRange(currentRow,
        3).setValue('Current Streak:');
    profiles.getRange(currentRow,
        4).setValue('--'); // Will be calculated
    currentRow++;
    
    profiles.getRange(currentRow,
        1).setValue('Best Partnership:');
    profiles.getRange(currentRow,
        2,
        1,
        2).merge().setValue('TBD'); // Complex query needed
    profiles.getRange(currentRow,
        4).setValue('Best Win Margin:');
    profiles.getRange(currentRow,
        5).setValue('--');
    currentRow++;
    
    profiles.getRange(currentRow,
        1).setValue('Worst Partnership:');
    profiles.getRange(currentRow,
        2,
        1,
        2).merge().setValue('TBD');
    profiles.getRange(currentRow,
        4).setValue('Worst Loss Margin:');
    profiles.getRange(currentRow,
        5).setValue('--');
    currentRow++;
    
    // Achievements
    currentRow++;
    profiles.getRange(currentRow,
        1,
        1,
        6).merge().setValue('🏅 ACHIEVEMENTS')
      .setFontWeight('bold').setBackground('#d9ead3');
    currentRow++;
    
    profiles.getRange(currentRow,
        1,
        1,
        6).merge().setValue('Achievement tracking coming soon...')
      .setFontStyle('italic').setFontColor('#666666');
    currentRow++;
    
    // Spacer
    currentRow += 2;
    });
  
  // Formatting
  profiles.setColumnWidth(1,
    180);
  profiles.setColumnWidth(2,
    120);
  profiles.setColumnWidth(3,
    180);
  profiles.setColumnWidth(4,
    120);
  profiles.setColumnWidth(5,
    120);
  profiles.setColumnWidth(6,
    120);
  
  return profiles;
}
