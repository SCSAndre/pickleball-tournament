function applyScheduleFormatting(sched) {
    // Win/Loss highlighting
  const ruleA = SpreadsheetApp.newConditionalFormatRule()
    .whenFormulaSatisfied('=$F2>$G2')
    .setBackground(CONFIG.COLORS.WIN)
    .setBold(true)
    .setRanges([sched.getRange('B2:C15')
    ])
    .build();
  
  const ruleB = SpreadsheetApp.newConditionalFormatRule()
    .whenFormulaSatisfied('=$G2>$F2')
    .setBackground(CONFIG.COLORS.WIN)
    .setBold(true)
    .setRanges([sched.getRange('D2:E15')
    ])
    .build();
  
  const ruleC = SpreadsheetApp.newConditionalFormatRule()
    .whenFormulaSatisfied('=$F2<$G2')
    .setBackground(CONFIG.COLORS.LOSS)
    .setRanges([sched.getRange('B2:C15')
    ])
    .build();
  
  const ruleD = SpreadsheetApp.newConditionalFormatRule()
    .whenFormulaSatisfied('=$G2<$F2')
    .setBackground(CONFIG.COLORS.LOSS)
    .setRanges([sched.getRange('D2:E15')
    ])
    .build();
  
  // Status indicators
  const ruleComplete = SpreadsheetApp.newConditionalFormatRule()
    .whenTextEqualTo('✓')
    .setBackground(CONFIG.COLORS.WIN)
    .setBold(true)
    .setRanges([sched.getRange('H2:H15')
    ])
    .build();
  
  const rulePending = SpreadsheetApp.newConditionalFormatRule()
    .whenTextEqualTo('⏳')
    .setBackground(CONFIG.COLORS.PENDING)
    .setRanges([sched.getRange('H2:H15')
    ])
    .build();
  
  // Score magnitude (gradient)
  const scoreGradient = SpreadsheetApp.newConditionalFormatRule()
    .setGradientMaxpointWithValue('#4caf50', SpreadsheetApp.InterpolationType.NUMBER, '30')
    .setGradientMinpointWithValue('#ffffff', SpreadsheetApp.InterpolationType.NUMBER, '0')
    .setRanges([sched.getRange('F2:G15')
    ])
    .build();
  
  const rules = [ruleA, ruleB, ruleC, ruleD, ruleComplete, rulePending, scoreGradient
    ];
  sched.setConditionalFormatRules(rules);
}

function applyScheduleAdvancedFormatting() {
  const ss = SpreadsheetApp.getActive();
  const sched = ss.getSheetByName('Schedule');
