function applyPartnershipsFormatting(part) {
    // Win/Loss colors
  const winRule = SpreadsheetApp.newConditionalFormatRule()
    .whenTextEqualTo('WIN')
    .setBackground(CONFIG.COLORS.WIN)
    .setBold(true)
    .setRanges([part.getRange('E2:E29')
    ])
    .build();
  
  const lossRule = SpreadsheetApp.newConditionalFormatRule()
    .whenTextEqualTo('LOSS')
    .setBackground(CONFIG.COLORS.LOSS)
    .setRanges([part.getRange('E2:E29')
    ])
    .build();
  
  // Team colors
  const teamARule = SpreadsheetApp.newConditionalFormatRule()
    .whenTextEqualTo('Team A')
    .setBackground('#e3f2fd')
    .setRanges([part.getRange('B2:B29')
    ])
    .build();
  
  const teamBRule = SpreadsheetApp.newConditionalFormatRule()
    .whenTextEqualTo('Team B')
    .setBackground('#fce4ec')
    .setRanges([part.getRange('B2:B29')
    ])
    .build();
  
  // Margin gradient
  const marginGradient = SpreadsheetApp.newConditionalFormatRule()
    .setGradientMaxpointWithValue(CONFIG.COLORS.SUCCESS, SpreadsheetApp.InterpolationType.NUMBER, '15')
    .setGradientMidpointWithValue('#ffffff', SpreadsheetApp.InterpolationType.NUMBER, '0')
    .setGradientMinpointWithValue(CONFIG.COLORS.DANGER, SpreadsheetApp.InterpolationType.NUMBER, '-15')
    .setRanges([part.getRange('F2:F29')
    ])
    .build();
  
  const rules = [winRule, lossRule, teamARule, teamBRule, marginGradient
    ];
  part.setConditionalFormatRules(rules);
}
