function getMatchList() {
  const ss = SpreadsheetApp.getActive();
  const sched = ss.getSheetByName('Schedule');
  
  const matches = [];
  for (let r = 2; r <= 15; r++) {
    const matchNum = sched.getRange(r,
        1).getValue();
    const teamA = sched.getRange(r,
        2).getValue() + ' + ' + sched.getRange(r,
        3).getValue();
    const teamB = sched.getRange(r,
        4).getValue() + ' + ' + sched.getRange(r,
        5).getValue();
    const status = sched.getRange(r,
        8).getValue();
    
    matches.push({
      number: matchNum,
      matchup: teamA + ' vs ' + teamB,
      status: status === '✓' ? '(✓)' : '(⏳)'
        });
    }
  
  return matches;
}

function getMatchDetails(matchNum) {
  const ss = SpreadsheetApp.getActive();
  const sched = ss.getSheetByName('Schedule');
  const row = parseInt(matchNum) + 1;
  
  return {
    teamA: sched.getRange(row,
        2).getValue() + ' + ' + sched.getRange(row,
        3).getValue(),
    teamB: sched.getRange(row,
        4).getValue() + ' + ' + sched.getRange(row,
        5).getValue(),
    scoreA: sched.getRange(row,
        6).getValue(),
    scoreB: sched.getRange(row,
        7).getValue()
    };
}

function saveMatchScore(matchNum, scoreA, scoreB) {
  try {
    const ss = SpreadsheetApp.getActive();
    const sched = ss.getSheetByName('Schedule');
    const row = parseInt(matchNum) + 1;
    
    if (!isValidScore(scoreA) || !isValidScore(scoreB)) {
      return { success: false, message: 'Invalid score values'
            };
        }
    
    sched.getRange(row,
        6).setValue(parseInt(scoreA));
    sched.getRange(row,
        7).setValue(parseInt(scoreB));
    sched.getRange(row,
        9).setValue(getTimestamp());
    
    logActivity('Match ' + matchNum + ' score entered: ' + scoreA + '-' + scoreB);
    
    // Check if all matches complete
    const completed = sched.getRange('H2:H15').getValues().filter(row => row[
            0
        ] === '✓').length;
    if (completed === 14) {
            // Tournament complete - could trigger winner announcement
      logActivity('Tournament completed - all matches finished');
        }
    
    return { success: true
        };
    } catch (e) {
    return { success: false, message: e.message
        };
    }
}
