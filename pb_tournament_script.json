function protectFormulaCells() {
  const ss = SpreadsheetApp.getActive();
  const ui = SpreadsheetApp.getUi();
  
  try {
        // List of sheets and ranges to protect
    const protections = [
            {sheet: 'Standings', range: 'B2:K9', desc: 'Standings calculations'
            },
            {sheet: 'Leaderboard', range: 'A2:L9', desc: 'Leaderboard auto-sort'
            },
            {sheet: 'Partnerships', range: 'A2:G29', desc: 'Partnership stats'
            },
            {sheet: 'Head-to-Head', range: 'B8:B22', desc: 'H2H calculations'
            },
            {sheet: 'Stats Dashboard', range: 'B5:H30', desc: 'Statistics'
            },
            {sheet: 'Partnership Compatibility', range: 'B5:G100', desc: 'Compatibility matrix'
            },
            {sheet: 'Player Profiles', range: 'B1:F200', desc: 'Player stats'
            },
            {sheet: 'Achievements', range: 'A1:H100', desc: 'Achievement tracking'
            },
            {sheet: 'Predictions', range: 'A1:K100', desc: 'Predictions & insights'
            },
            {sheet: 'Schedule', range: 'H2:I15', desc: 'Match status'
            }
        ];
    
    protections.forEach(p => {
      const sheet = ss.getSheetByName(p.sheet);
      if (sheet) {
        try {
          const protection = sheet.getRange(p.range).protect();
          protection.setDescription(p.desc + ' - Auto-calculated');
          protection.setWarningOnly(true);
                } catch (e) {
          console.log(`Could not protect ${p.sheet
                    }: ${e.message
                    }`);
                }
            }
        });
    
    ui.alert('✅ Protection Applied', 'Formula cells are now protected from accidental edits.', ui.ButtonSet.OK);
    logActivity('Formula cells protected');
    } catch (e) {
    ui.alert('⚠️ Protection Error', 'Some cells could not be protected: ' + e.message, ui.ButtonSet.OK);
    }
}

function clearScoresOnly() {
