/**
 * Announces tournament winners
 */
function announceWinners() {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActive();
  
  // Check if tournament is complete
  const sched = ss.getSheetByName('Schedule');
  const completed = sched.getRange('H2:H15').getValues().filter(row => row[
        0
    ] === '✓').length;
  
  if (completed < 14) {
    ui.alert(
      'Tournament Incomplete',
      `Only ${completed
        } of 14 matches completed. Cannot announce winners yet.`,
      ui.ButtonSet.OK
    );
    return;
    }
  
  const response = ui.alert(
    '🎉 Announce Winners',
    'This will send a championship email to all players. Continue?',
    ui.ButtonSet.YES_NO
  );
  
  if (response !== ui.Button.YES) {
    return;
    }
  
  try {
    const players = ss.getSheetByName('Players');
    const leaderboard = ss.getSheetByName('Leaderboard');
    
    const playerData = players.getRange('A2:E9').getValues();
    const winner = leaderboard.getRange('B2').getValue();
    const winnerPoints = leaderboard.getRange('C2').getValue();
    
    let emailsSent = 0;
    
    playerData.forEach(row => {
      const email = row[
                1
            ];
      const notificationEnabled = row[
                3
            ];
      
      if (notificationEnabled === 'Yes' && email && email.includes('@')) {
        try {
          const emailBody = buildWinnersEmail(winner, winnerPoints, ss.getUrl());
          
          MailApp.sendEmail({
            to: email,
            subject: `🏆 ${CONFIG.TOURNAMENT_NAME
                        } - CHAMPIONS ANNOUNCED!`,
            htmlBody: emailBody
                    });
          
          emailsSent++;
                } catch (e) {
          console.log(`Failed to send winner email: ${e.message
                    }`);
                }
            }
        });
    
    logActivity(`Winner announcement emails sent: ${emailsSent
        }`);
    
    ui.alert('🎉 Success', `Championship emails sent to ${emailsSent
        } players!`, ui.ButtonSet.OK);
    } catch (e) {
    ui.alert('Error', `Failed to announce winners: ${e.message
        }`, ui.ButtonSet.OK);
    }
}

