// ============================================================================

function createPartnershipCompatibility(ss) {
  if (!ss) ss = SpreadsheetApp.getActive();
  
  const compat = getOrCreateSheet(ss, 'Partnership Compatibility');
  compat.clear();
  
  // Title
  compat.getRange('A1').setValue('🤝 PARTNERSHIP COMPATIBILITY MATRIX').setFontSize(18).setFontWeight('bold');
  compat.getRange('A2').setValue('Analysis of player combinations - Win rates and performance metrics')
    .setFontSize(10).setFontColor('#666666');
  
  // Headers
  compat.getRange('A4:G4').setValues([
        ['Partnership','Matches','Wins','Losses','Win %','Avg Margin','Rating'
        ]
    ]).setFontWeight('bold').setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff');
  
  // Get unique partnerships
  const players = ['Dedezito','Guguzito','Cebolito','Nayzito','Michelito','Tiaguito','Marcito','Fernandito'
    ];
  let row = 5;
  let partnerships = [];
  
  // Generate all possible partnerships from schedule
  const ss2 = SpreadsheetApp.getActive();
  const sched = ss2.getSheetByName('Schedule');
  
  for (let r = 2; r <= 15; r++) {
    const p1 = sched.getRange(r,
        2).getValue();
    const p2 = sched.getRange(r,
        3).getValue();
    const p3 = sched.getRange(r,
        4).getValue();
    const p4 = sched.getRange(r,
        5).getValue();
    
    const pair1 = [p1, p2
        ].sort().join(' + ');
    const pair2 = [p3, p4
        ].sort().join(' + ');
    
    if (!partnerships.includes(pair1)) partnerships.push(pair1);
    if (!partnerships.includes(pair2)) partnerships.push(pair2);
    }
  
  partnerships = partnerships.sort();
  
  // Add formulas for each partnership
  partnerships.forEach((partnership, idx) => {
    const currentRow = row + idx;
    
    compat.getRange(currentRow,
        1).setValue(partnership);
    
    // Matches played
    compat.getRange(currentRow,
        2).setFormula(
      `=COUNTIF(Partnerships!C2:C29,
        "${partnership}")`
    );
    
    // Wins
    compat.getRange(currentRow,
        3).setFormula(
      `=COUNTIFS(Partnerships!C2:C29,
        "${partnership}",Partnerships!E2:E29,
        "WIN")`
    );
    
    // Losses
    compat.getRange(currentRow,
        4).setFormula(
      `=COUNTIFS(Partnerships!C2:C29,
        "${partnership}",Partnerships!E2:E29,
        "LOSS")`
    );
    
    // Win %
    compat.getRange(currentRow,
        5).setFormula(
      `=IF(B${currentRow
        }=0,
        0,C${currentRow
        }/B${currentRow
        })`
    );
    
    // Avg Margin
    compat.getRange(currentRow,
        6).setFormula(
      `=IF(B${currentRow
        }=0,
        0,AVERAGEIF(Partnerships!C2:C29,
        "${partnership}",Partnerships!F2:F29))`
    );
    
    // Rating (custom score based on win % and margin)
    compat.getRange(currentRow,
        7).setFormula(
      `=IF(B${currentRow
        }=0,
        0,ROUND(E${currentRow
        }*70+MIN(F${currentRow
        }/10,
        30),
        1))`
    );
    });
  
  // Formatting
  compat.setFrozenRows(4);
  compat.autoResizeColumns(1,
    7);
  compat.getRange(5,
    5, partnerships.length,
    1).setNumberFormat('0.0%');
  compat.getRange(5,
    6, partnerships.length,
    1).setNumberFormat('0.0');
  compat.getRange(5,
    7, partnerships.length,
    1).setNumberFormat('0.0');
  
  // Conditional formatting for win %
  const winPctRule = SpreadsheetApp.newConditionalFormatRule()
    .setGradientMaxpointWithValue(CONFIG.COLORS.SUCCESS, SpreadsheetApp.InterpolationType.NUMBER, '1')
    .setGradientMidpointWithValue('#ffffff', SpreadsheetApp.InterpolationType.NUMBER, '0.5')
    .setGradientMinpointWithValue(CONFIG.COLORS.DANGER, SpreadsheetApp.InterpolationType.NUMBER, '0')
    .setRanges([compat.getRange(5,
        5, partnerships.length,
        1)
    ])
    .build();
  
  // Rating color scale
  const ratingRule = SpreadsheetApp.newConditionalFormatRule()
    .setGradientMaxpointWithValue(CONFIG.COLORS.GOLD, SpreadsheetApp.InterpolationType.NUMBER, '100')
    .setGradientMidpointWithValue('#ffffff', SpreadsheetApp.InterpolationType.NUMBER, '50')
    .setGradientMinpointWithValue('#cccccc', SpreadsheetApp.InterpolationType.NUMBER, '0')
    .setRanges([compat.getRange(5,
        7, partnerships.length,
        1)
    ])
    .build();
  
  const rules = [winPctRule, ratingRule
    ];
  compat.setConditionalFormatRules(rules);
  
  // Add Top Partnerships section
  const topRow = row + partnerships.length + 2;
  compat.getRange(topRow,
    1,
    1,
    7).merge().setValue('⭐ TOP 5 PARTNERSHIPS').setFontSize(14).setFontWeight('bold')
    .setBackground(CONFIG.COLORS.GOLD).setHorizontalAlignment('center');
  
  compat.getRange(topRow + 1,
    1).setFormula(
    `=SORT(A5:G${row + partnerships.length - 1
    },
    7,FALSE)`
  );
  
  // Add Worst Partnerships section
  const worstRow = topRow + 7;
  compat.getRange(worstRow,
    1,
    1,
    7).merge().setValue('⚠️ NEEDS IMPROVEMENT').setFontSize(14).setFontWeight('bold')
    .setBackground(CONFIG.COLORS.DANGER).setFontColor('#ffffff').setHorizontalAlignment('center');
  
  compat.getRange(worstRow + 1,
    1).setFormula(
    `=SORT(FILTER(A5:G${row + partnerships.length - 1
    },B5:B${row + partnerships.length - 1
    }>0),
    7,TRUE)`
  );
  
  return compat;
}
