  stats.getRange('C12:D12').merge().setFormula('=INDEX(Leaderboard!B:B,
    4)');
  stats.getRange('E12').setFormula('=INDEX(Leaderboard!C:C,
    4)&" pts"');
  
  // Performance Metrics
  stats.getRange('A14:H14').merge().setValue('📈 TOP PERFORMERS').setFontSize(14).setFontWeight('bold')
    .setBackground(CONFIG.COLORS.SUCCESS).setFontColor('#ffffff').setHorizontalAlignment('center');
  
  stats.getRange('A15:B15').merge().setValue('Most Wins:').setFontWeight('bold');
  stats.getRange('C15:D15').merge().setFormula('=INDEX(SORT(Standings!A2:C9,
    3,FALSE),
    1,
    1)');
  stats.getRange('E15').setFormula('=MAX(Standings!C2:C9)&" wins"');
  
  stats.getRange('A16:B16').merge().setValue('Best Win %:').setFontWeight('bold');
  stats.getRange('C16:D16').merge().setFormula('=INDEX(SORT(Standings!A2:I9,
    9,FALSE),
    1,
    1)');
  stats.getRange('E16').setFormula('=TEXT(MAX(Standings!I2:I9),
    "0.0%")');
  
  stats.getRange('A17:B17').merge().setValue('Most Points Scored:').setFontWeight('bold');
  stats.getRange('C17:D17').merge().setFormula('=INDEX(SORT(Standings!A2:E9,
    5,FALSE),
    1,
    1)');
  stats.getRange('E17').setFormula('=MAX(Standings!E2:E9)&" pts"');
  
  stats.getRange('A18:B18').merge().setValue('Best Point Diff:').setFontWeight('bold');
  stats.getRange('C18:D18').merge().setFormula('=INDEX(SORT(Standings!A2:G9,
    7,FALSE),
    1,
    1)');
  stats.getRange('E18').setFormula('=TEXT(MAX(Standings!G2:G9),
    "+0;-0;0")');
  
  stats.getRange('A19:B19').merge().setValue('Stingiest Defense:').setFontWeight('bold');
  stats.getRange('C19:D19').merge().setFormula('=INDEX(SORT(Standings!A2:F9,
    6,TRUE),
    1,
    1)');
  stats.getRange('E19').setFormula('=MIN(Standings!F2:F9)&" allowed"');
  
  // Tournament Totals
  stats.getRange('A21:H21').merge().setValue('🎯 TOURNAMENT STATISTICS').setFontSize(14).setFontWeight('bold')
    .setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff').setHorizontalAlignment('center');
  
  stats.getRange('A22:B22').merge().setValue('Total Points Scored:').setFontWeight('bold');
  stats.getRange('C22').setFormula('=SUM(Schedule!F2:G15)');
  
  stats.getRange('E22:F22').merge().setValue('Avg Per Match:').setFontWeight('bold');
  stats.getRange('G22').setFormula('=IF(C6>0,C22/(C6*2),
    0)');
  stats.getRange('G22').setNumberFormat('0.0');
  
  stats.getRange('A23:B23').merge().setValue('Highest Score:').setFontWeight('bold');
  stats.getRange('C23').setFormula('=MAX(Schedule!F2:G15)');
  
  stats.getRange('E23:F23').merge().setValue('Lowest Score:').setFontWeight('bold');
  stats.getRange('G23').setFormula('=IF(C6>0,MIN(IF(Schedule!F2:F15<>"",Schedule!F2:F15),IF(Schedule!G2:G15<>"",Schedule!G2:G15)),
    0)');
  
  stats.getRange('A24:B24').merge().setValue('Avg Win Margin:').setFontWeight('bold');
  stats.getRange('C24').setFormula('=IF(C6>0,AVERAGE(ABS(Schedule!F2:F15-Schedule!G2:G15)),
    0)');
  stats.getRange('C24').setNumberFormat('0.0');
  
  stats.getRange('E24:F24').merge().setValue('Closest Match:').setFontWeight('bold');
  stats.getRange('G24').setFormula('=IF(C6>0,MIN(ABS(Schedule!F2:F15-Schedule!G2:G15)),
    0)');
  
  stats.getRange('A25:B25').merge().setValue('Biggest Blowout:').setFontWeight('bold');
  stats.getRange('C25').setFormula('=IF(C6>0,MAX(ABS(Schedule!F2:F15-Schedule!G2:G15)),
    0)');
  
  // Recent Matches
  stats.getRange('A27:H27').merge().setValue('🕒 RECENT RESULTS (Last 5)').setFontSize(14).setFontWeight('bold')
    .setBackground(CONFIG.COLORS.WARNING).setHorizontalAlignment('center');
  
  stats.getRange('A28:E28').setValues([
        ['Match','Matchup','Score','Winner','Margin'
        ]
    ]);
  stats.getRange('A28:E28').setFontWeight('bold').setBackground('#f5f5f5');
  
  // Formatting
  stats.setColumnWidths(1,
    2,
    120);
  stats.setColumnWidths(3,
    2,
    150);
  stats.setColumnWidth(5,
    150);
  stats.setColumnWidths(6,
    3,
    100);
  
  return stats;
}
