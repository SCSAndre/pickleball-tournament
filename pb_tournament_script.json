function createPredictionsSheet(ss) {
  if (!ss) ss = SpreadsheetApp.getActive();
  
  const pred = getOrCreateSheet(ss, 'Predictions');
  pred.clear();
  
  // Title
  pred.getRange('A1').setValue('🔮 AI-POWERED PREDICTIONS & INSIGHTS').setFontSize(18).setFontWeight('bold');
  pred.getRange('A2').setValue('Statistical analysis and outcome predictions')
    .setFontSize(10).setFontColor('#666666');
  
  // Current Form Indicator
  pred.getRange('A4:E4').merge().setValue('🔥 PLAYER FORM INDICATORS').setFontSize(14).setFontWeight('bold')
    .setBackground(CONFIG.COLORS.WARNING).setHorizontalAlignment('center');
  
  pred.getRange('A5:E5').setValues([
        ['Player','Status','Win%','Trend','Prediction'
        ]
    ])
    .setFontWeight('bold').setBackground('#f5f5f5');
  
  const players = ['Dedezito','Guguzito','Cebolito','Nayzito','Michelito','Tiaguito','Marcito','Fernandito'
    ];
  
  players.forEach((player, idx) => {
    const row = 6 + idx;
    pred.getRange(row,
        1).setValue(player);
    
    // Status (Hot/Cold/Neutral)
    pred.getRange(row,
        2).setFormula(
      `=IF(VLOOKUP("${player}",Standings!A2:I9,
        9,FALSE)>0.6,
        "🔥 HOT",IF(VLOOKUP("${player}",Standings!A2:I9,
        9,FALSE)<0.4,
        "🧊 COLD",
        "➖ Neutral"))`
    );
    
    // Win %
    pred.getRange(row,
        3).setFormula(`=VLOOKUP("${player}",Standings!A2:I9,
        9,FALSE)`);
    pred.getRange(row,
        3).setNumberFormat('0.0%');
    
    // Trend (placeholder)
    pred.getRange(row,
        4).setValue('--');
    
    // Prediction
    pred.getRange(row,
        5).setValue('TBD');
    });
  
  // Projected Final Standings
  pred.getRange('A16:E16').merge().setValue('📊 PROJECTED FINAL STANDINGS').setFontSize(14).setFontWeight('bold')
    .setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff').setHorizontalAlignment('center');
  
  pred.getRange('A17:E17').setValues([
        ['Projected Rank','Player','Current Points','Projected Points','Change'
        ]
    ])
    .setFontWeight('bold').setBackground('#f5f5f5');
  
  // Copy current standings and add projections
  pred.getRange('A18').setFormula('=Leaderboard!A2:A9');
  pred.getRange('B18').setFormula('=Leaderboard!B2:B9');
  pred.getRange('C18').setFormula('=Leaderboard!C2:C9');
  
  // Projected points (current + estimated from remaining matches)
  for (let i = 0; i < 8; i++) {
    const row = 18 + i;
    pred.getRange(row,
        4).setFormula(
      `=C${row
        }+ROUND((VLOOKUP(B${row
        },Standings!A2:I9,
        9,FALSE)*2*(14-'Stats Dashboard'!C6)/8),
        0)`
    );
    pred.getRange(row,
        5).setFormula(`=D${row
        }-C${row
        }`);
    }
    // Match Predictions
  pred.getRange('G4:K4').merge().setValue('⚔️ UPCOMING MATCH PREDICTIONS').setFontSize(14).setFontWeight('bold')
    .setBackground(CONFIG.COLORS.SUCCESS).setFontColor('#ffffff').setHorizontalAlignment('center');
  
  pred.getRange('G5:K5').setValues([
        ['Match','Team A','Team B','Predicted Winner','Confidence'
        ]
    ])
    .setFontWeight('bold').setBackground('#f5f5f5');
  
  // Show next 5 pending matches
  pred.getRange('G6').setValue('Analyzing remaining matches...');
  
  // Insights Section
  pred.getRange('G16:K16').merge().setValue('💡 KEY INSIGHTS').setFontSize(14).setFontWeight('bold')
    .setBackground(CONFIG.COLORS.WARNING).setHorizontalAlignment('center');
  
  pred.getRange('G17').setValue('• Statistical insights will appear here');
  pred.getRange('G18').setValue('• Based on completed matches');
  pred.getRange('G19').setValue('• Updated in real-time');
  
  // Formatting
  pred.setColumnWidths(1,
    5,
    130);
  pred.setColumnWidths(7,
    5,
    130);
  
  // Conditional formatting for form
  const hotRule = SpreadsheetApp.newConditionalFormatRule()
    .whenTextContains('HOT')
    .setBackground(CONFIG.COLORS.HOT)
    .setFontColor('#ffffff')
    .setRanges([pred.getRange('B6:B13')
    ])
    .build();
  
  const coldRule = SpreadsheetApp.newConditionalFormatRule()
    .whenTextContains('COLD')
    .setBackground(CONFIG.COLORS.COLD)
    .setFontColor('#ffffff')
    .setRanges([pred.getRange('B6:B13')
    ])
    .build();
  
  pred.setConditionalFormatRules([hotRule, coldRule
    ]);
  
  return pred;
}
