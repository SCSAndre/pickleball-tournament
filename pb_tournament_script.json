function createProgressSheet(ss) {
  const prog = getOrCreateSheet(ss, 'Progress Tracker');
  prog.clear();
  
  prog.getRange('A1').setValue('⏱️ MATCH PROGRESS TRACKER').setFontSize(16).setFontWeight('bold');
  
  prog.getRange('A3:F3').setValues([
        ['Match','Matchup','Status','Completion','Date','Notes'
        ]
    ]).setFontWeight('bold').setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff');
  
  for (let r = 2; r <= 15; r++) {
    const row = r + 2;
    prog.getRange(row,
        1).setFormula('=Schedule!A' + r);
    prog.getRange(row,
        2).setFormula('=Schedule!B' + r + '&" + "&Schedule!C' + r + '&" vs "&Schedule!D' + r + '&" + "&Schedule!E' + r);
    prog.getRange(row,
        3).setFormula('=Schedule!H' + r);
    prog.getRange(row,
        4).setFormula('=IF(Schedule!H' + r + '="✓",
        "100%",
        "0%")');
    prog.getRange(row,
        5).setValue('');
    prog.getRange(row,
        6).setValue('');
    }
  
  prog.setFrozenRows(3);
  prog.autoResizeColumns(1,
    6);
  prog.setColumnWidth(2,
    350);
  prog.setColumnWidth(6,
    200);
  
  // Conditional formatting
  const completeRule = SpreadsheetApp.newConditionalFormatRule()
    .whenTextEqualTo('✓')
    .setBackground(CONFIG.COLORS.WIN)
    .setRanges([prog.getRange('C4:C17')
    ])
    .build();
  
  const pendingRule = SpreadsheetApp.newConditionalFormatRule()
    .whenTextEqualTo('⏳')
    .setBackground(CONFIG.COLORS.PENDING)
    .setRanges([prog.getRange('C4:C17')
    ])
    .build();
  
  prog.setConditionalFormatRules([completeRule, pendingRule
    ]);
}
