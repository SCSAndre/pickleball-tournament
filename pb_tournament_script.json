  stats.getRange('A2').setValue('Last Updated: ' + getTimestamp()).setFontSize(10).setFontColor('#666666');
  stats.getRange('A1:H1').mergeAcross();
  stats.getRange('A2:H2').mergeAcross();
  
  // Tournament Overview
  stats.getRange('A4:H4').merge().setValue('🏁 TOURNAMENT OVERVIEW').setFontSize(14).setFontWeight('bold')
    .setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff').setHorizontalAlignment('center');
  
  stats.getRange('A5:B5').merge().setValue('Total Matches:').setFontWeight('bold');
  stats.getRange('C5').setValue(14);
  
  stats.getRange('E5:F5').merge().setValue('Total Players:').setFontWeight('bold');
  stats.getRange('G5').setValue(8);
  
  stats.getRange('A6:B6').merge().setValue('Completed:').setFontWeight('bold');
  stats.getRange('C6').setFormula('=COUNTIF(Schedule!H2:H15,
    "✓")');
  
  stats.getRange('E6:F6').merge().setValue('Remaining:').setFontWeight('bold');
  stats.getRange('G6').setFormula('=14-C6');
  
  stats.getRange('A7:B7').merge().setValue('Progress:').setFontWeight('bold');
  stats.getRange('C7').setFormula('=C6/14');
  stats.getRange('C7').setNumberFormat('0.0%');
  
