function createScheduleSheet(ss) {
  const sched = getOrCreateSheet(ss, 'Schedule');
  sched.clear();
  
  sched.getRange('A1:I1').setValues([
        ['Match','TeamA_P1','TeamA_P2','TeamB_P1','TeamB_P2','ScoreA','ScoreB','Status','Date'
        ]
    ]);

  const matches = [
        [
            1,'Dedezito','Fernandito','Nayzito','Michelito','','','⏳',''
        ],
        [
            2,'Guguzito','Marcito','Cebolito','Tiaguito','','','⏳',''
        ],
        [
            3,'Dedezito','Marcito','Cebolito','Nayzito','','','⏳',''
        ],
        [
            4,'Fernandito','Tiaguito','Guguzito','Michelito','','','⏳',''
        ],
        [
            5,'Dedezito','Tiaguito','Guguzito','Cebolito','','','⏳',''
        ],
        [
            6,'Marcito','Michelito','Fernandito','Nayzito','','','⏳',''
        ],
        [
            7,'Dedezito','Michelito','Fernandito','Guguzito','','','⏳',''
        ],
        [
            8,'Tiaguito','Nayzito','Marcito','Cebolito','','','⏳',''
        ],
        [
            9,'Dedezito','Nayzito','Marcito','Fernandito','','','⏳',''
        ],
        [
            10,'Michelito','Cebolito','Tiaguito','Guguzito','','','⏳',''
        ],
        [
            11,'Dedezito','Cebolito','Tiaguito','Marcito','','','⏳',''
        ],
        [
            12,'Nayzito','Guguzito','Michelito','Fernandito','','','⏳',''
        ],
        [
            13,'Dedezito','Guguzito','Michelito','Tiaguito','','','⏳',''
        ],
        [
            14,'Cebolito','Fernandito','Nayzito','Marcito','','','⏳',''
        ]
    ];
  
  sched.getRange(2,
    1, matches.length,
    9).setValues(matches);
  
  // Status formulas
  for (let r = 2; r <= 15; r++) {
    sched.getRange(r,
        8).setFormula(
      '=IF(AND(ISNUMBER(F' + r + '),ISNUMBER(G' + r + ')),
        "✓",
        "⏳")'
    );
    }
    // Formatting
  sched.setFrozenRows(1);
  sched.autoResizeColumns(1,
    9);
  sched.getRange('A1:I1').setFontWeight('bold').setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff');
  sched.getRange('F2:G15').setNumberFormat('0');
  sched.setColumnWidth(8,
    60);
  
  // Data validation
  const scoreValidation = SpreadsheetApp.newDataValidation()
    .requireNumberGreaterThanOrEqualTo(0)
    .setAllowInvalid(false)
    .setHelpText('Enter non-negative number')
    .build();
  
  sched.getRange('F2:G15').setDataValidation(scoreValidation);
  
  // Conditional formatting (will be enhanced later)
  applyScheduleFormatting(sched);
}

function createStandingsSheet(ss) {
  const std = getOrCreateSheet(ss, 'Standings');
  std.clear();
  
  std.getRange('A1:K1').setValues([
        ['Player','Points','Wins','Losses','PF','PA','Diff','Rank','Win%','Form','Streak'
        ]
    ]);

  const players = [
        ['Dedezito'
        ],
        ['Guguzito'
        ],
        ['Cebolito'
        ],
        ['Nayzito'
        ],
        ['Michelito'
        ],
        ['Tiaguito'
        ],
        ['Marcito'
        ],
        ['Fernandito'
        ]
    ];
  
  std.getRange(2,
    1, players.length,
    1).setValues(players);

  for (let r = 2; r <= 9; r++) {
        // Points
    std.getRange(r,
        2).setFormula(
      '=2*(SUMPRODUCT(((Schedule!B$2:B$15=A' + r + ')+(Schedule!C$2:C$15=A' + r + '))*(Schedule!F$2:F$15>Schedule!G$2:G$15))+SUMPRODUCT(((Schedule!D$2:D$15=A' + r + ')+(Schedule!E$2:E$15=A' + r + '))*(Schedule!G$2:G$15>Schedule!F$2:F$15)))'
    );
    
    // Wins
    std.getRange(r,
        3).setFormula(
      '=SUMPRODUCT(((Schedule!B$2:B$15=A' + r + ')+(Schedule!C$2:C$15=A' + r + '))*(Schedule!F$2:F$15>Schedule!G$2:G$15))+SUMPRODUCT(((Schedule!D$2:D$15=A' + r + ')+(Schedule!E$2:E$15=A' + r + '))*(Schedule!G$2:G$15>Schedule!F$2:F$15))'
    );
    
    // Losses
    std.getRange(r,
        4).setFormula(
      '=SUMPRODUCT(((Schedule!B$2:B$15=A' + r + ')+(Schedule!C$2:C$15=A' + r + '))*(Schedule!F$2:F$15<Schedule!G$2:G$15))+SUMPRODUCT(((Schedule!D$2:D$15=A' + r + ')+(Schedule!E$2:E$15=A' + r + '))*(Schedule!G$2:G$15<Schedule!F$2:F$15))'
    );
    
    // Points For
    std.getRange(r,
        5).setFormula(
      '=SUMPRODUCT(((Schedule!B$2:B$15=A' + r + ')+(Schedule!C$2:C$15=A' + r + '))*(Schedule!F$2:F$15))+SUMPRODUCT(((Schedule!D$2:D$15=A' + r + ')+(Schedule!E$2:E$15=A' + r + '))*(Schedule!G$2:G$15))'
    );
    
    // Points Against
    std.getRange(r,
        6).setFormula(
      '=SUMPRODUCT(((Schedule!B$2:B$15=A' + r + ')+(Schedule!C$2:C$15=A' + r + '))*(Schedule!G$2:G$15))+SUMPRODUCT(((Schedule!D$2:D$15=A' + r + ')+(Schedule!E$2:E$15=A' + r + '))*(Schedule!F$2:F$15))'
    );
    
    // Diff
    std.getRange(r,
        7).setFormula('=E' + r + '-F' + r);
    
    // Rank
    std.getRange(r,
        8).setFormula(
      '=RANK(B' + r + ',$B$2:$B$9,
        0)+COUNTIFS($B$2:$B$9,B' + r + ',$G$2:$G$9,
        ">"&G' + r + ')'
    );
    
    // Win %
    std.getRange(r,
        9).setFormula(
      '=IF(C' + r + '+D' + r + '=0,
        0,C' + r + '/(C' + r + '+D' + r + '))'
    );
    
    // Form (last 3 matches - will be calculated by script)
    std.getRange(r,
        10).setValue('--');
    
    // Streak
    std.getRange(r,
        11).setValue('--');
    }

  std.setFrozenRows(1);
  std.autoResizeColumns(1,
    11);
  std.getRange('A1:K1').setFontWeight('bold').setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff');
  std.getRange('B2:H9').setNumberFormat('0');
  std.getRange('I2:I9').setNumberFormat('0.0%');
  
  applyStandingsFormatting(std);
}

function createLeaderboardSheet(ss) {
  const lb = getOrCreateSheet(ss, 'Leaderboard');
  lb.clear();
  
  lb.getRange('A1:L1').setValues([
        ['Pos','Player','Points','Wins','Losses','PF','PA','Diff','Rank','Win%','Form','Medal'
        ]
    ]);
  
  // Add position numbers
  for (let i = 1; i <= 8; i++) {
    lb.getRange(i + 1,
        1).setValue(i);
    }
    // Sort formula
  lb.getRange('B2').setFormula(
    '=SORT(Standings!A2:K9,Standings!B2:B9,FALSE,Standings!G2:G9,FALSE)'
  );
  
  lb.setFrozenRows(1);
  lb.autoResizeColumns(1,
    12);
  lb.getRange('A1:L1').setFontWeight('bold').setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff');
  
  // Medal emojis
  lb.getRange('L2').setValue('🥇').setFontSize(24);
  lb.getRange('L3').setValue('🥈').setFontSize(24);
  lb.getRange('L4').setValue('🥉').setFontSize(24);
  
  // Podium colors
  lb.getRange('A2:L2').setBackground(CONFIG.COLORS.GOLD).setFontWeight('bold');
  lb.getRange('A3:L3').setBackground(CONFIG.COLORS.SILVER).setFontWeight('bold');
  lb.getRange('A4:L4').setBackground(CONFIG.COLORS.BRONZE).setFontWeight('bold');
  
  lb.setColumnWidth(12,
    60);
}

function createPartnershipsSheet(ss) {
  const part = getOrCreateSheet(ss, 'Partnerships');
  part.clear();
  
  part.getRange('A1:G1').setValues([
        ['Match','Team','Partnership','Scored','Result','Margin','Quality'
        ]
    ]);
  
  let row = 2;
  for (let r = 2; r <= 15; r++) {
        // Team A
    part.getRange(row,
        1).setFormula('=Schedule!A' + r);
    part.getRange(row,
        2).setValue('Team A');
    part.getRange(row,
        3).setFormula('=Schedule!B' + r + '&" + "&Schedule!C' + r);
    part.getRange(row,
        4).setFormula('=Schedule!F' + r);
    part.getRange(row,
        5).setFormula('=IF(Schedule!F' + r + '>Schedule!G' + r + ',
        "WIN",IF(Schedule!F' + r + '<Schedule!G' + r + ',
        "LOSS",IF(AND(ISNUMBER(Schedule!F' + r + '),ISNUMBER(Schedule!G' + r + ')),
        "TIE",
        "")))');
    part.getRange(row,
        6).setFormula('=Schedule!F' + r + '-Schedule!G' + r);
    part.getRange(row,
        7).setFormula('=IF(E' + row + '="WIN",IF(F' + row + '>10,
        "⭐⭐⭐",IF(F' + row + '>5,
        "⭐⭐",
        "⭐")),IF(E' + row + '="LOSS",
        "",
        ""))');
    row++;
    
    // Team B
    part.getRange(row,
        1).setFormula('=Schedule!A' + r);
    part.getRange(row,
        2).setValue('Team B');
    part.getRange(row,
        3).setFormula('=Schedule!D' + r + '&" + "&Schedule!E' + r);
    part.getRange(row,
        4).setFormula('=Schedule!G' + r);
    part.getRange(row,
        5).setFormula('=IF(Schedule!G' + r + '>Schedule!F' + r + ',
        "WIN",IF(Schedule!G' + r + '<Schedule!F' + r + ',
        "LOSS",IF(AND(ISNUMBER(Schedule!F' + r + '),ISNUMBER(Schedule!G' + r + ')),
        "TIE",
        "")))');
    part.getRange(row,
        6).setFormula('=Schedule!G' + r + '-Schedule!F' + r);
    part.getRange(row,
        7).setFormula('=IF(E' + row + '="WIN",IF(F' + row + '>10,
        "⭐⭐⭐",IF(F' + row + '>5,
        "⭐⭐",
        "⭐")),IF(E' + row + '="LOSS",
        "",
        ""))');
    row++;
    }
  
  part.setFrozenRows(1);
  part.autoResizeColumns(1,
    7);
  part.getRange('A1:G1').setFontWeight('bold').setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff');
  
  applyPartnershipsFormatting(part);
}

function createHeadToHeadSheet(ss) {
  const h2h = getOrCreateSheet(ss, 'Head-to-Head');
  h2h.clear();
  
  h2h.getRange('A1').setValue('🔍 HEAD-TO-HEAD ANALYSIS').setFontSize(18).setFontWeight('bold');
  h2h.getRange('A3').setValue('Player 1:').setFontWeight('bold');
  h2h.getRange('A4').setValue('Player 2:').setFontWeight('bold');
  
  const players = ['Dedezito','Guguzito','Cebolito','Nayzito','Michelito','Tiaguito','Marcito','Fernandito'
    ];
  const validation = SpreadsheetApp.newDataValidation().requireValueInList(players).build();
  h2h.getRange('B3').setDataValidation(validation);
  h2h.getRange('B4').setDataValidation(validation);
  
  h2h.getRange('A6').setValue('🤝 AS PARTNERS').setFontSize(14).setFontWeight('bold').setBackground('#e8f0fe');
  h2h.getRange('A7:B7').setValues([
        ['Metric','Value'
        ]
    ]).setFontWeight('bold').setBackground('#d0e1f9');
  
  h2h.getRange('A8:A13').setValues([
        ['Matches Together'
        ],
        ['Record (W-L)'
        ],
        ['Win Rate'
        ],
        ['Points Scored'
        ],
        ['Points Allowed'
        ],
        ['Avg Margin'
        ]
    ]);
  
  h2h.getRange('A15').setValue('⚔️ AS OPPONENTS').setFontSize(14).setFontWeight('bold').setBackground('#fce8e6');
  h2h.getRange('A16:B16').setValues([
        ['Metric','Value'
        ]
    ]).setFontWeight('bold').setBackground('#f4cccc');
  
  h2h.getRange('A17:A22').setValues([
        ['Matches Faced'
        ],
        ['Player 1 Wins'
        ],
        ['Player 2 Wins'
        ],
        ['Player 1 Avg Score'
        ],
        ['Player 2 Avg Score'
        ],
        ['Head-to-Head Leader'
        ]
    ]);
  
  // Formulas for Partners
  h2h.getRange('B8').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4)),
    "",SUMPRODUCT(((Schedule!B$2:B$15=B3)*(Schedule!C$2:C$15=B4))+((Schedule!B$2:B$15=B4)*(Schedule!C$2:C$15=B3))+((Schedule!D$2:D$15=B3)*(Schedule!E$2:E$15=B4))+((Schedule!D$2:D$15=B4)*(Schedule!E$2:E$15=B3))))'
  );
  
  h2h.getRange('B9').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4)),
    "",SUMPRODUCT(((Schedule!B$2:B$15=B3)*(Schedule!C$2:C$15=B4)+(Schedule!B$2:B$15=B4)*(Schedule!C$2:C$15=B3))*(Schedule!F$2:F$15>Schedule!G$2:G$15))+SUMPRODUCT(((Schedule!D$2:D$15=B3)*(Schedule!E$2:E$15=B4)+(Schedule!D$2:D$15=B4)*(Schedule!E$2:E$15=B3))*(Schedule!G$2:G$15>Schedule!F$2:F$15))&"-"&SUMPRODUCT(((Schedule!B$2:B$15=B3)*(Schedule!C$2:C$15=B4)+(Schedule!B$2:B$15=B4)*(Schedule!C$2:C$15=B3))*(Schedule!F$2:F$15<Schedule!G$2:G$15))+SUMPRODUCT(((Schedule!D$2:D$15=B3)*(Schedule!E$2:E$15=B4)+(Schedule!D$2:D$15=B4)*(Schedule!E$2:E$15=B3))*(Schedule!G$2:G$15<Schedule!F$2:F$15)))'
  );
  
  h2h.getRange('B10').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4),B8=0),
    "",TEXT((SUMPRODUCT(((Schedule!B$2:B$15=B3)*(Schedule!C$2:C$15=B4)+(Schedule!B$2:B$15=B4)*(Schedule!C$2:C$15=B3))*(Schedule!F$2:F$15>Schedule!G$2:G$15))+SUMPRODUCT(((Schedule!D$2:D$15=B3)*(Schedule!E$2:E$15=B4)+(Schedule!D$2:D$15=B4)*(Schedule!E$2:E$15=B3))*(Schedule!G$2:G$15>Schedule!F$2:F$15)))/B8,
    "0.0%"))'
  );
  
  h2h.getRange('B11').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4)),
    "",SUMPRODUCT(((Schedule!B$2:B$15=B3)*(Schedule!C$2:C$15=B4)+(Schedule!B$2:B$15=B4)*(Schedule!C$2:C$15=B3))*(Schedule!F$2:F$15))+SUMPRODUCT(((Schedule!D$2:D$15=B3)*(Schedule!E$2:E$15=B4)+(Schedule!D$2:D$15=B4)*(Schedule!E$2:E$15=B3))*(Schedule!G$2:G$15)))'
  );
  
  h2h.getRange('B12').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4)),
    "",SUMPRODUCT(((Schedule!B$2:B$15=B3)*(Schedule!C$2:C$15=B4)+(Schedule!B$2:B$15=B4)*(Schedule!C$2:C$15=B3))*(Schedule!G$2:G$15))+SUMPRODUCT(((Schedule!D$2:D$15=B3)*(Schedule!E$2:E$15=B4)+(Schedule!D$2:D$15=B4)*(Schedule!E$2:E$15=B3))*(Schedule!F$2:F$15)))'
  );
  
  h2h.getRange('B13').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4),B8=0),
    "",(B11-B12)/B8)'
  );
  
  // Formulas for Opponents
  h2h.getRange('B17').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4)),
    "",SUMPRODUCT(((Schedule!B$2:B$15=B3)+(Schedule!C$2:C$15=B3))*((Schedule!D$2:D$15=B4)+(Schedule!E$2:E$15=B4)))+SUMPRODUCT(((Schedule!D$2:D$15=B3)+(Schedule!E$2:E$15=B3))*((Schedule!B$2:B$15=B4)+(Schedule!C$2:C$15=B4))))'
  );
  
  h2h.getRange('B18').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4)),
    "",SUMPRODUCT(((Schedule!B$2:B$15=B3)+(Schedule!C$2:C$15=B3))*((Schedule!D$2:D$15=B4)+(Schedule!E$2:E$15=B4))*(Schedule!F$2:F$15>Schedule!G$2:G$15))+SUMPRODUCT(((Schedule!D$2:D$15=B3)+(Schedule!E$2:E$15=B3))*((Schedule!B$2:B$15=B4)+(Schedule!C$2:C$15=B4))*(Schedule!G$2:G$15>Schedule!F$2:F$15)))'
  );
  
  h2h.getRange('B19').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4)),
    "",SUMPRODUCT(((Schedule!B$2:B$15=B4)+(Schedule!C$2:C$15=B4))*((Schedule!D$2:D$15=B3)+(Schedule!E$2:E$15=B3))*(Schedule!F$2:F$15>Schedule!G$2:G$15))+SUMPRODUCT(((Schedule!D$2:D$15=B4)+(Schedule!E$2:E$15=B4))*((Schedule!B$2:B$15=B3)+(Schedule!C$2:C$15=B3))*(Schedule!G$2:G$15>Schedule!F$2:F$15)))'
  );
  
  h2h.getRange('B20').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4),B17=0),
    "",ROUND((SUMPRODUCT(((Schedule!B$2:B$15=B3)+(Schedule!C$2:C$15=B3))*((Schedule!D$2:D$15=B4)+(Schedule!E$2:E$15=B4))*(Schedule!F$2:F$15))+SUMPRODUCT(((Schedule!D$2:D$15=B3)+(Schedule!E$2:E$15=B3))*((Schedule!B$2:B$15=B4)+(Schedule!C$2:C$15=B4))*(Schedule!G$2:G$15)))/B17,
    1))'
  );
  
  h2h.getRange('B21').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4),B17=0),
    "",ROUND((SUMPRODUCT(((Schedule!B$2:B$15=B4)+(Schedule!C$2:C$15=B4))*((Schedule!D$2:D$15=B3)+(Schedule!E$2:E$15=B3))*(Schedule!F$2:F$15))+SUMPRODUCT(((Schedule!D$2:D$15=B4)+(Schedule!E$2:E$15=B4))*((Schedule!B$2:B$15=B3)+(Schedule!C$2:C$15=B3))*(Schedule!G$2:G$15)))/B17,
    1))'
  );
  
  h2h.getRange('B22').setFormula(
    '=IF(OR(ISBLANK(B3),ISBLANK(B4)),
    "",IF(B18>B19,B3&" leads "&B18&"-"&B19,IF(B19>B18,B4&" leads "&B19&"-"&B18,
    "Tied "&B18&"-"&B19)))'
  );
  
  h2h.setColumnWidth(1,
    200);
  h2h.setColumnWidth(2,
    150);
  h2h.autoResizeColumns(1,
    2);
}

