/**
 * Creates a specially formatted sheet for PDF export
 */
function createPDFSummarySheet() {
  const ss = SpreadsheetApp.getActive();
  const summary = getOrCreateSheet(ss, 'PDF Export Summary');
  summary.clear();
  
  // Title Page
  summary.getRange('A1:H1').merge().setValue(`🏆 ${CONFIG.TOURNAMENT_NAME
    }`)
    .setFontSize(28).setFontWeight('bold').setHorizontalAlignment('center');
  
  summary.getRange('A2:H2').merge().setValue('FINAL TOURNAMENT REPORT')
    .setFontSize(18).setHorizontalAlignment('center');
  
  summary.getRange('A3:H3').merge().setValue(getTimestamp())
    .setFontSize(12).setHorizontalAlignment('center').setFontColor('#666666');
  
  // Executive Summary
  summary.getRange('A5:H5').merge().setValue('📊 EXECUTIVE SUMMARY')
    .setFontSize(16).setFontWeight('bold').setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff');
  
  summary.getRange('A7:B7').merge().setValue('Tournament Status:');
  summary.getRange('C7:D7').merge().setValue('COMPLETE').setFontWeight('bold').setFontColor(CONFIG.COLORS.SUCCESS);
  
  summary.getRange('A8:B8').merge().setValue('Total Matches:');
  summary.getRange('C8').setValue(14);
  
  summary.getRange('A9:B9').merge().setValue('Total Players:');
  summary.getRange('C9').setValue(8);
  
  summary.getRange('A10:B10').merge().setValue('Champion:');
  summary.getRange('C10:D10').merge().setFormula('=Leaderboard!B2').setFontWeight('bold').setFontSize(14);
  
  // Final Standings
  summary.getRange('A13:H13').merge().setValue('🏆 FINAL STANDINGS')
    .setFontSize(16).setFontWeight('bold').setBackground(CONFIG.COLORS.GOLD);
  
  summary.getRange('A14').setFormula('=Leaderboard!A1:J9');
  
  // Key Statistics
  summary.getRange('A24:H24').merge().setValue('📈 KEY STATISTICS')
    .setFontSize(16).setFontWeight('bold').setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff');
  
  // Copy relevant stats from Stats Dashboard
  summary.getRange('A26:B26').merge().setValue('Most Wins:');
  summary.getRange('C26:D26').merge().setFormula('=INDEX(SORT(Standings!A2:C9,
    3,FALSE),
    1,
    1)');
  
  summary.getRange('A27:B27').merge().setValue('Highest Win %:');
  summary.getRange('C27:D27').merge().setFormula('=INDEX(SORT(Standings!A2:I9,
    9,FALSE),
    1,
    1)');
  
  summary.getRange('A28:B28').merge().setValue('Best Point Diff:');
  summary.getRange('C28:D28').merge().setFormula('=INDEX(SORT(Standings!A2:G9,
    7,FALSE),
    1,
    1)');
  
  // Top Partnerships
  summary.getRange('A31:H31').merge().setValue('🤝 TOP PARTNERSHIPS')
    .setFontSize(16).setFontWeight('bold').setBackground(CONFIG.COLORS.SUCCESS).setFontColor('#ffffff');
  
  summary.getRange('A32').setFormula('=SORT(\'Partnership Compatibility\'!A5:G30,
    7,FALSE)');
  
  // Formatting
  summary.setColumnWidths(1,
    8,
    120);
  
  // Set print settings
  summary.getRange('A1:H50').setFontFamily('Arial');
  
  SpreadsheetApp.getUi().alert(
    '✅ PDF Summary Created',
    'A formatted summary sheet has been created!\n\n' +
    'To export:\n' +
    '1. Select the "PDF Export Summary" sheet\n' +
    '2. File → Download → PDF\n' +
    '3. Export!',
    SpreadsheetApp.getUi().ButtonSet.OK
  );
  
  ss.setActiveSheet(summary);
}
