function backupTournament() {
  const ss = SpreadsheetApp.getActive();
  const ui = SpreadsheetApp.getUi();
  
  try {
    const timestamp = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd_HHmmss');
    const backupName = 'Backup_' + timestamp;
    
    const sched = ss.getSheetByName('Schedule');
    if (sched) {
      const backup = sched.copyTo(ss);
      backup.setName(backupName);
      
      backup.getRange('K1').setValue('Backup Date:');
      backup.getRange('L1').setValue(getTimestamp());
      
      logActivity('Backup created: ' + backupName);
      ui.alert('✅ Backup Created', 'Tournament data backed up to sheet: ' + backupName, ui.ButtonSet.OK);
        }
    } catch (e) {
    ui.alert('❌ Backup Failed', 'Error creating backup: ' + e.message, ui.ButtonSet.OK);
    }
}

function archiveAndStartNew() {
  const ui = SpreadsheetApp.getUi();
  const response = ui.alert(
    'Archive & Start New',
    'This will archive the current tournament and start fresh. Continue?',
    ui.ButtonSet.YES_NO
  );
  
  if (response !== ui.Button.YES) {
    return;
    }
  
  backupTournament();
  
  const ss = SpreadsheetApp.getActive();
  const archive = getOrCreateSheet(ss, 'Archive');
  
  const timestamp = getTimestamp();
  const nextRow = archive.getLastRow() + 1;
  
  if (nextRow === 1) {
    archive.getRange('A1:D1').setValues([
            ['Date', 'Winner', 'Points', 'Backup Sheet'
            ]
        ]);
    archive.getRange('A1:D1').setFontWeight('bold').setBackground(CONFIG.COLORS.PRIMARY).setFontColor('#ffffff');
    }
  
  const lb = ss.getSheetByName('Leaderboard');
  if (lb) {
    const winner = lb.getRange('B2').getValue();
    const points = lb.getRange('C2').getValue();
    archive.getRange(nextRow + 1,
        1).setValue(timestamp);
    archive.getRange(nextRow + 1,
        2).setValue(winner);
    archive.getRange(nextRow + 1,
        3).setValue(points);
    archive.getRange(nextRow + 1,
        4).setValue('Backup_' + timestamp.substring(0,
        19).replace(' ', '_'));
    }
  
  setupTournament();
  
  ui.alert('✅ Complete', 'Tournament archived and new tournament created!', ui.ButtonSet.OK);
}

