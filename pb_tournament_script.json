/**
 * Sends standings email to all players
 */
function emailStandingsToAll() {
  const ui = SpreadsheetApp.getUi();
  
  if (!CONFIG.ENABLE_EMAIL_NOTIFICATIONS) {
    ui.alert('Email Disabled', 'Email notifications are currently disabled. Enable in configuration.', ui.ButtonSet.OK);
    return;
    }
  
  const response = ui.alert(
    'Send Standings Email',
    'This will send current standings to all players with notifications enabled. Continue?',
    ui.ButtonSet.YES_NO
  );
  
  if (response !== ui.Button.YES) {
    return;
    }
  
  try {
    const ss = SpreadsheetApp.getActive();
    const players = ss.getSheetByName('Players');
    const leaderboard = ss.getSheetByName('Leaderboard');
    
    if (!players || !leaderboard) {
      ui.alert('Error', 'Required sheets not found. Please run setup first.', ui.ButtonSet.OK);
      return;
        }
        // Get player data
    const playerData = players.getRange('A2:E9').getValues();
    const standingsData = leaderboard.getRange('A1:J9').getValues();
    
    let emailsSent = 0;
    let emailsFailed = 0;
    
    playerData.forEach(row => {
      const playerName = row[
                0
            ];
      const email = row[
                1
            ];
      const notificationEnabled = row[
                3
            ];
      
      if (notificationEnabled === 'Yes' && email && email.includes('@')) {
        try {
          const emailBody = buildStandingsEmail(playerName, standingsData, ss.getUrl());
          
          MailApp.sendEmail({
            to: email,
            subject: `🏆 ${CONFIG.TOURNAMENT_NAME
                        } - Standings Update`,
            htmlBody: emailBody
                    });
          
          emailsSent++;
                } catch (e) {
          console.log(`Failed to send email to ${playerName
                    }: ${e.message
                    }`);
          emailsFailed++;
                }
            }
        });
    
    logActivity(`Standings emails sent: ${emailsSent
        } successful, ${emailsFailed
        } failed`);
    
    ui.alert(
      '📧 Emails Sent',
      `Successfully sent ${emailsSent
        } emails.\nFailed: ${emailsFailed
        }`,
      ui.ButtonSet.OK
    );
    } catch (e) {
    ui.alert('Error', `Failed to send emails: ${e.message
        }`, ui.ButtonSet.OK);
    }
}
/**
 * Builds HTML email for standings
 */
function buildStandingsEmail(playerName, standingsData, sheetUrl) {
  let html = `
    <!DOCTYPE html>
    <html>
    <head>
      <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333;
    }
        .container { max-width: 600px; margin: 0 auto; padding: 20px;
    }
        .header { background: ${CONFIG.COLORS.PRIMARY
        }; color: white; padding: 20px; text-align: center; border-radius: 8px 8px 0 0;
    }
        .content { background: #f9f9f9; padding: 20px;
    }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; background: white;
    }
        th { background: ${CONFIG.COLORS.PRIMARY
        }; color: white; padding: 12px; text-align: left;
    }
        td { padding: 10px; border-bottom: 1px solid #ddd;
    }
        tr:hover { background: #f5f5f5;
    }
        .highlight { background: ${CONFIG.COLORS.GOLD
        } !important; font-weight: bold;
    }
        .player-stats { background: #e8f0fe; padding: 15px; border-radius: 5px; margin: 15px 0;
    }
        .button { display: inline-block; padding: 12px 24px; background: ${CONFIG.COLORS.SUCCESS
        }; color: white; text-decoration: none; border-radius: 5px; margin: 10px 0;
    }
        .footer { text-align: center; padding: 20px; color: #666; font-size: 12px;
    }
        .medal { font-size: 24px;
    }
      </style>
    </head>
    <body>
      <div class="container">
        <div class="header">
          <h1>🏆 ${CONFIG.TOURNAMENT_NAME
    }</h1>
          <p>Current Standings Update</p>
        </div>
        
        <div class="content">
          <p>Hello <strong>${playerName
    }</strong>!</p>
          <p>Here are the current tournament standings as of ${getTimestamp()
    }:</p>
          
          <table>
            <thead>
              <tr>
                <th>Rank</th>
                <th>Player</th>
                <th>Points</th>
                <th>W-L</th>
                <th>Win %</th>
                <th>Diff</th>
              </tr>
            </thead>
            <tbody>
  `;
  
  // Add standings rows
  for (let i = 1; i < standingsData.length; i++) {
    const row = standingsData[i
        ];
    const isPlayer = row[
            1
        ] === playerName;
    const rowClass = isPlayer ? 'highlight' : '';
    const medal = i === 1 ? '🥇' : i === 2 ? '🥈' : i === 3 ? '🥉' : '';
    
    html += `
      <tr class="${rowClass}">
        <td>${row[
                0
            ]
        } ${medal
        }</td>
        <td><strong>${row[
                1
            ]
        }</strong></td>
        <td>${row[
                2
            ]
        }</td>
        <td>${row[
                3
            ]
        }-${row[
                4
            ]
        }</td>
        <td>${(row[
                9
            ] * 100).toFixed(1)
        }%</td>
        <td>${row[
                7
            ] > 0 ? '+' : ''
        }${row[
                7
            ]
        }</td>
      </tr>
    `;
    }
  
  html += `
            </tbody>
          </table>
          
          <div class="player-stats">
            <h3>📊 Your Performance</h3>
            <p>Keep up the great work, ${playerName
    }! Check the full dashboard for detailed statistics.</p>
          </div>
          
          <center>
            <a href="${sheetUrl}" class="button">View Full Dashboard</a>
          </center>
          
          <p style="margin-top: 20px;">
            <strong>Next Steps:</strong><br>
            • Check upcoming matches in the Schedule<br>
            • Review your partnerships and strategies<br>
            • Good luck in your remaining matches!
          </p>
        </div>
        
        <div class="footer">
          <p>This is an automated message from the Tournament Management System</p>
          <p>To stop receiving these emails, update your notification settings in the Players sheet</p>
        </div>
      </div>
    </body>
    </html>
  `;
  
  return html;
}
